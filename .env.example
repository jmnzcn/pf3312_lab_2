# Copia este archivo a .env y rellena las API keys que vayas obteniendo.
# El .env real está en .gitignore para que NUNCA se suba al repo.

# === LLM ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
GOOGLE_API_KEY=
GROQ_API_KEY=
OLLAMA_HOST=http://localhost:11434

# === STT ===
# OpenAI Whisper API usa la misma OPENAI_API_KEY de arriba.
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=westus
AZURE_SPEECH_LANGUAGE=es-CR

# === TTS ===
# OpenAI TTS usa la misma OPENAI_API_KEY de arriba.
ELEVENLABS_API_KEY=
GOOGLE_APPLICATION_CREDENTIALS=secrets/gcp-tts-key.json
# Para Google Cloud TTS: JSON de cuenta de servicio (carpeta secrets/ en .gitignore).

# Azure TTS comparte AZURE_SPEECH_KEY y AZURE_SPEECH_REGION de arriba.

# === Modelos locales ===
OLLAMA_MODEL=llama3.2:3b
FASTER_WHISPER_MODEL=large-v3
FASTER_WHISPER_COMPUTE_TYPE=int8_float16
PIPER_MODEL_PATH=models/piper/es_ES-davefx-medium.onnx
PIPER_BIN=tools/piper/piper/piper.exe
PIPER_CWD=tools/piper/piper
